# Server
PORT=3000
APP_URL="http://localhost:3000"

# Provider selection
# AI_PROVIDER can be: auto, gemini, openai, anthropic, groq
AI_PROVIDER="auto"
AI_FALLBACK_ORDER="gemini,openai,anthropic,groq"

# Model overrides
AI_MODEL=""
AI_ANALYSIS_MODEL=""

# Provider keys
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""

# Optional override for OpenAI-compatible deployments
OPENAI_BASE_URL="https://api.openai.com/v1"
